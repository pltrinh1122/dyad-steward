{
  "permissions": {
    "allow": [
      "Bash(git push origin:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f*)",
      "Bash(git push * -f*)",
      "Bash(git push --delete*)",
      "Bash(git push * --delete*)",
      "Bash(git push * -d*)",
      "Bash(git push +*)",
      "Bash(git push * +*)",
      "Bash(git push * :*)"
    ]
  }
}
